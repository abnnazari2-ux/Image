# Database (used with Prisma when STORAGE_PROVIDER=prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/image_edit_studio"

# Image editing provider: "mock" | "replicate"
IMAGE_EDITOR_PROVIDER="mock"

# Storage provider: "local" | "s3"
STORAGE_PROVIDER="local"

# Replicate (required when IMAGE_EDITOR_PROVIDER=replicate)
# REPLICATE_API_TOKEN="r8_..."
# REPLICATE_MODEL="stability-ai/sdxl:latest"

# S3 (required when STORAGE_PROVIDER=s3)
# S3_BUCKET="my-image-edits"
# S3_REGION="us-east-1"
# S3_ENDPOINT="https://s3.amazonaws.com"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_CDN_URL="https://cdn.example.com"
